<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext (http) nur zum lokalen Dev-Server. 10.0.2.2 = Host-Rechner
     aus Sicht des Android-Emulators. Für Tests auf einem echten Gerät die
     LAN-IP des Entwicklungsrechners als weitere <domain> eintragen.
     Produktion läuft ausschließlich über https. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
